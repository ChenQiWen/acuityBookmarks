{
  "name": "acuitybookmarks-root",
  "private": true,
  "version": "1.0.0",
  "description": "AcuityBookmarks monorepo (Bun workspaces)",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "website",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.2.21",
  "resolutions": {
    "zod": "^3.25.8",
    "@types/node": "^24.3.0",
    "postcss": "^8.4.41",
    "stylelint": "^16.25.0",
    "typescript": "~5.8.3",
    "eslint": "^9.35.0",
    "vue": "^3.5.18",
    "@supabase/supabase-js": "^2.79.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    
    "clean:deps": "rm -rf node_modules frontend/node_modules backend/node_modules website/node_modules packages/*/node_modules bun.lockb frontend/bun.lock backend/bun.lock 2>/dev/null || true && echo '🧹 清理完成'",
    "reinstall": "bun run clean:deps && bun install && echo '✅ 依赖已清理并重新安装'",
    
    "dev": "bunx turbo run dev",
    "dev:fe": "bunx turbo run dev --filter=frontend",
    "dev:be": "bunx turbo run dev --filter=backend",
    "dev:web": "bunx turbo run dev --filter=acuitybookmarks-website",
    
    "build": "bunx turbo run build",
    "build:fe": "bunx turbo run build --filter=frontend",
    "build:be": "bunx turbo run build --filter=backend",
    "build:web": "bunx turbo run build --filter=acuitybookmarks-website",
    "build:prod": "NODE_ENV=production bunx turbo run build",
    
    "watch": "bunx turbo run build:watch --filter=frontend dev --filter=backend dev --filter=acuitybookmarks-website --parallel --ui=tui",
    "watch:fe": "bunx turbo run build:watch --filter=frontend",
    
    "test": "bunx turbo run test --filter=frontend",
    "test:fe": "bunx turbo run test --filter=frontend",
    "test:be": "bunx turbo run test --filter=backend",
    
    "typecheck": "bunx turbo run typecheck",
    "lint": "bun ./scripts/smart-lint.mjs",
    "format": "bunx prettier --write \"**/*.{js,ts,json,md,vue}\"",
    "stylelint": "bunx turbo run stylelint --filter=frontend",
    "stylelint:fix": "bunx turbo run stylelint:fix --filter=frontend",
    
    "deploy:be": "bunx turbo run deploy --filter=backend",
    "deploy:web": "bunx turbo run build --filter=acuitybookmarks-website && echo 'Website build complete. Deploy dist/ directory to your hosting service.'",
    
    "audit:fe": "bun run build:fe && bunx -y @lhci/cli autorun --config ./frontend/lighthouserc.json && bun ./scripts/lhci-summary.mjs && bun ./scripts/open-median-reports.mjs frontend",
    "audit:web": "cd website && bun run generate && bunx -y @lhci/cli autorun --config ./lighthouserc.json && bun ../scripts/lhci-summary-website.mjs && bun ../scripts/open-median-reports.mjs website",
    
    "clean": "bunx turbo run clean",
    
    "e2e": "bun ./scripts/e2e-management.mjs --ext ${EXT_ID:-gdjcmpenmogdikhnnaebmddhmdgbfcgl}",
    "e2e:perf": "bun ./scripts/e2e-management.mjs --ext ${EXT_ID:-gdjcmpenmogdikhnnaebmddhmdgbfcgl} --perf --cpu ${CPU_RATE:-4} --net ${NET_PRESET:-slow4g}",
    "e2e:all": "bun run e2e && bun run e2e:perf",
    
    "db:start": "bunx turbo run db:start --filter=backend",
    "db:stop": "bunx turbo run db:stop --filter=backend",
    "db:reset": "bunx turbo run db:reset --filter=backend",
    "db:new": "bunx turbo run db:new --filter=backend",
    "db:logs": "bunx turbo run logs --filter=backend",
    
    "export:env": "bun ./scripts/export-env.mjs --ext ${EXT_ID:-gdjcmpenmogdikhnnaebmddhmdgbfcgl}",
    "import:env": "bun ./scripts/import-env.mjs --ext ${EXT_ID:-gdjcmpenmogdikhnnaebmddhmdgbfcgl}"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-plugin-vue": "^10.4.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.41",
    "postcss-html": "^1.7.0",
    "stylelint": "^16.25.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^7.0.0",
    "supabase": "^2.66.0",
    "turbo": "^2.9.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.43.0"
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.8"
  }
}
